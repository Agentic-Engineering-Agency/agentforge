# E2E Test Environment Configuration
#
# Copy this to .env.e2e and fill in values:
#   cp .env.e2e.example .env.e2e
#
# For local development with docker-compose:
#   docker compose -f tests/docker-compose.e2e.yml up -d
#   Then use the defaults below.

# Cloud API URL (default: local docker-compose)
AGENTFORGE_CLOUD_URL=http://localhost:3001

# Convex backend URL (default: local docker-compose)
CONVEX_URL=http://localhost:3210

# Test API key (must match Cloud API config)
AGENTFORGE_TEST_API_KEY=test-api-key-e2e

# OpenAI API key (optional — skips real LLM tests if missing)
# OPENAI_API_KEY=sk-...

# Test user ID (scopes all test operations)
E2E_TEST_USER_ID=e2e-test-user

# CI flag (set automatically in GitHub Actions)
# CI=true
