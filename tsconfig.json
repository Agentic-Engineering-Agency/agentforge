{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@agentforge-ai/core": ["packages/core/src/index.ts"],
      "@agentforge-ai/core/*": ["packages/core/src/*"],
      "@agentforge-ai/runtime": ["packages/runtime/src/index.ts"],
      "@agentforge-ai/runtime/*": ["packages/runtime/src/*"]
    },
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
