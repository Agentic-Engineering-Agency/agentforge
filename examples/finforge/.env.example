# FinForge Demo — Environment Variables
# Copy this file to .env and fill in your keys.

# --- LLM Provider (Bring Your Own Key) ---
# AgentForge supports any AI SDK-compatible provider.
# This demo uses OpenAI, but you can swap in Anthropic, Google, etc.
OPENAI_API_KEY=sk-your-openai-key-here

# --- E2B Sandbox (for secure tool execution) ---
E2B_API_KEY=e2b_your-key-here

# --- Convex (auto-configured by `npx convex dev`) ---
# CONVEX_URL is set automatically when you run the Convex dev server.
