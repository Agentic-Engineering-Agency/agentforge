{
  "name": "@agentforge-ai/core",
  "version": "0.12.10",
  "description": "Core agent primitives, sandbox integration, and MCP server for AgentForge",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agent": {
      "types": "./dist/agent.d.ts",
      "import": "./dist/agent.js"
    },
    "./sandbox": {
      "types": "./dist/sandbox/index.d.ts",
      "import": "./dist/sandbox/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp-server.d.ts",
      "import": "./dist/mcp-server.js"
    },
    "./browser": {
      "types": "./dist/browser-tool.d.ts",
      "import": "./dist/browser-tool.js"
    },
    "./workspace": {
      "types": "./dist/workspace.d.ts",
      "import": "./dist/workspace.js"
    },
    "./channels/telegram": {
      "types": "./dist/channels/telegram.d.ts",
      "import": "./dist/channels/telegram.js"
    },
    "./channels/whatsapp": {
      "types": "./dist/channels/whatsapp.d.ts",
      "import": "./dist/channels/whatsapp.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/google": "^1.0.0",
    "@discordjs/rest": "^2.4.0",
    "@e2b/code-interpreter": "^1.0.0",
    "@mastra/core": "^1.5.0",
    "@mastra/s3": "^0.2.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@slack/bolt": "^4.1.0",
    "@slack/web-api": "^7.8.0",
    "discord.js": "^14.16.0",
    "dockerode": "^4.0.9",
    "playwright": ">=1.40.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.47",
    "playwright": "^1.58.2",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "ai",
    "agents",
    "mastra",
    "mcp",
    "e2b",
    "sandbox",
    "workspace",
    "multi-agent",
    "telegram",
    "whatsapp",
    "channels",
    "browser",
    "playwright",
    "automation"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Agentic-Engineering-Agency/agentforge.git",
    "directory": "packages/core"
  }
}
