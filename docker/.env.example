# ─────────────────────────────────────────────────────────────────────────
# AgentForge Agent Sandbox — Environment Variables
# ─────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your API keys.
# Only set the keys for the agents you want to use.
# ─────────────────────────────────────────────────────────────────────────

# OpenAI — Required for Codex CLI and Aider (default)
OPENAI_API_KEY=

# Anthropic — Required for Claude Code
ANTHROPIC_API_KEY=

# Google — Required for Gemini CLI
GOOGLE_API_KEY=

# OpenRouter — Required for OpenCode (multi-model routing)
OPENROUTER_API_KEY=
